{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@odic/ui": ["packages/ui/src"],
      "@odic/workspace-core": ["packages/workspace-core/src"],
      "@odic/graph": ["packages/graph/src"],
      "@odic/ai-gia": ["packages/ai-gia/src"]
    }
  }
}
